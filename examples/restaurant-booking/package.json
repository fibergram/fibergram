{
  "name": "@fibergram/example-restaurant-booking",
  "version": "0.0.0",
  "private": true,
  "description": "Restaurant table-booking bot — a full fibergram example: coroutine wizards, inline menus, Fluent i18n, durable KeyValueStore persistence",
  "type": "module",
  "license": "MIT",
  "sideEffects": [],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "test": "vitest run",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "effect": "catalog:",
    "@fibergram/core": "workspace:^",
    "@fibergram/menu": "workspace:^",
    "@fibergram/i18n": "workspace:^",
    "@fibergram/durable": "workspace:^"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
