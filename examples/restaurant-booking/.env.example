# Copy to `.env` (or export these) before running the bot.

# Required — get one from @BotFather.
BOT_TOKEN=123456:your-telegram-bot-token

# Optional — shown in messages. Defaults to "Bella Vista".
RESTAURANT_NAME=Bella Vista

# Optional — directory the durable KeyValueStore writes to. Defaults to "./.data".
DATA_DIR=./.data
