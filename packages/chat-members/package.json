{
  "name": "@fibergram/chat-members",
  "version": "0.0.0",
  "description": "Chat-membership cache fed by chat_member updates, behind a KeyValueStore port",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/fibergram/fibergram/tree/main/packages/chat-members",
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "test": "vitest run",
    "check:exports": "attw --pack . --profile esm-only",
    "docgen": "docgen"
  },
  "dependencies": {
    "effect": "catalog:",
    "@fibergram/core": "workspace:^"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@effect/docgen": "catalog:",
    "@effect/vitest": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
