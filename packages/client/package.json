{
  "name": "@fibergram/client",
  "version": "0.0.0",
  "description": "TelegramClient (Tag+Layer over HttpClient) + Bot API Schema types",
  "type": "module",
  "license": "MIT",
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "check:exports": "attw --pack . --profile esm-only",
    "docgen": "docgen"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@effect/docgen": "catalog:",
    "@effect/vitest": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
