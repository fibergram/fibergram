{
  "name": "@fibergram/core",
  "version": "0.1.0",
  "description": "Dialog/decider, receive, Decision, EntityManager, Router, typed errors, CallbackData",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/fibergram/fibergram/tree/main/packages/core",
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "default": "./dist/client/index.js"
    },
    "./polling": {
      "types": "./dist/polling/index.d.ts",
      "import": "./dist/polling/index.js",
      "default": "./dist/polling/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js",
      "default": "./dist/ui/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "test": "vitest run",
    "check:exports": "attw --pack . --profile esm-only",
    "docgen": "docgen"
  },
  "dependencies": {
    "effect": "catalog:"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@effect/docgen": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
