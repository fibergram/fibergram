{
  "name": "@fibergram/webhook",
  "version": "0.0.0",
  "description": "Ingestion Layer: HttpServer + secret-token validation, framework-agnostic WebhookHandler",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/fibergram/fibergram/tree/main/packages/webhook",
  "sideEffects": [],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./express": {
      "types": "./dist/Express.d.ts",
      "import": "./dist/Express.js",
      "default": "./dist/Express.js"
    },
    "./fastify": {
      "types": "./dist/Fastify.d.ts",
      "import": "./dist/Fastify.js",
      "default": "./dist/Fastify.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "eslint .",
    "test": "vitest run",
    "check:exports": "attw --pack . --profile esm-only",
    "docgen": "docgen"
  },
  "dependencies": {
    "effect": "catalog:",
    "@fibergram/core": "workspace:^"
  },
  "peerDependencies": {
    "express": "^5.0.0",
    "fastify": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "catalog:",
    "@effect/docgen": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/express": "catalog:",
    "@types/node": "catalog:",
    "express": "catalog:",
    "fastify": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
